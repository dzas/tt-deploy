# TrustTunnel installer configuration.
# Run sequence:
#   ./tt-installer.sh plan --config ./installer.env --secrets ./secrets.env --interactive
#   ./tt-installer.sh apply --config ./installer.env --secrets ./secrets.env

# Runtime directory for installer artifacts (state, report, generated scripts).
INSTALL_ROOT=/opt/tt-installer

# TrustTunnel data directory on host (mounted as /trusttunnel_endpoint in container).
TT_DATA_DIR=/opt/trusttunnel

# TrustTunnel container name.
TT_CONTAINER_NAME=trusttunnel

# Endpoint image (default value set for this repo).
TT_IMAGE=ghcr.io/dzas/tt-endpoint:1.0.33

# REQUIRED: Public endpoint hostname used by clients.
# Example: test.example.com
TT_ENDPOINT_FQDN=

# Endpoint listen port.
TT_LISTEN_PORT=443

# Enable HTTP/3 metadata flag.
TT_ENABLE_HTTP3=true

# Docker network mode for endpoint container.
TT_NETWORK_MODE=host

# TrustTunnel log level (used in generated tt-up script metadata).
TT_LOG_LEVEL=debug

# Optional: strict DNS check in plan mode.
# If set, plan fails when TT_ENDPOINT_FQDN resolves to another IP.
# TT_DOMAIN_IP_EXPECTED=203.0.113.10

# Optional: source directory with prebuilt config files.
# TT_CONFIG_SOURCE_DIR=/root/bootstrap-config

# Initial setup mode when required files are missing:
#   wizard          - interactive setup_wizard (default, recommended)
#   non-interactive - setup_wizard with env inputs
TT_SETUP_MODE=wizard

# TLS mode:
#   letsencrypt-http01 (recommended)
#   existing-cert
#   self-signed
#   letsencrypt-dns01 (manual in current installer)
TLS_MODE=letsencrypt-http01

# Optional in wizard mode: Let's Encrypt account email.
# REQUIRED only for TT_SETUP_MODE=non-interactive with TLS_MODE=letsencrypt-http01.
LE_EMAIL=

# Optional in wizard mode: domain to validate.
# REQUIRED only for TT_SETUP_MODE=non-interactive with TLS_MODE=letsencrypt-http01.
# Usually same as TT_ENDPOINT_FQDN.
LE_DOMAIN=

# ACME challenge mode metadata for non-interactive flow.
LE_CHALLENGE=http01

# Optional future DNS-01 provider hint.
# LE_DNS_PROVIDER=

# REQUIRED for TLS_MODE=existing-cert: certificate chain path on host.
# If path is under TT_DATA_DIR, installer maps it to /trusttunnel_endpoint/... automatically.
# Example: /opt/trusttunnel/certs/fullchain.pem
EXISTING_CERT_PATH=

# REQUIRED for TLS_MODE=existing-cert: private key path on host.
# Example: /opt/trusttunnel/certs/privkey.pem
EXISTING_KEY_PATH=

# Enable UFW baseline rules.
UFW_ENABLE=true

# SSH port allowed in UFW.
UFW_ALLOW_SSH_PORT=22

# Allow 80/tcp (required for LE HTTP-01).
UFW_ALLOW_HTTP80=true

# Allow 443/tcp for endpoint traffic.
UFW_ALLOW_HTTPS443=true

# Enable fail2ban baseline setup.
F2B_ENABLE=true

# fail2ban sshd max retries.
F2B_SSHD_MAXRETRY=5

# fail2ban ban duration.
F2B_BANTIME=1h

# Enable Telegram admin bot deployment.
BOT_ENABLE=true

# Bot container name.
BOT_CONTAINER_NAME=trusttunnel-admin-bot

# Bot image (default value set for this repo).
BOT_IMAGE=ghcr.io/dzas/tt_admin_bot:v1.0.1

# Path to generated bot env file.
BOT_ENV_FILE=/opt/trusttunnel-admin-bot/.env

# Host directory mounted into bot container for credentials access.
BOT_TT_DATA_DIR=/opt/trusttunnel

# Print resume command on failure.
RESUME_ON_ERROR=true

# Installer state file path.
STATE_PATH=/opt/tt-installer/state.json

# Installer report file path.
REPORT_PATH=/opt/tt-installer/report.md
