# TrustTunnel installer secrets.
# Keep permissions strict:
#   chmod 600 ./secrets.env

# REQUIRED when BOT_ENABLE=true: Telegram bot token from BotFather.
TELEGRAM_BOT_TOKEN=

# REQUIRED when BOT_ENABLE=true: allowed Telegram user IDs (comma-separated).
# Example: 123456789,987654321
TELEGRAM_ALLOWED_USER_IDS=

# Bootstrap user for first-time non-interactive setup mode.
# Required only when TT_SETUP_MODE=non-interactive and config files are missing.
TT_BOOTSTRAP_USERNAME=
TT_BOOTSTRAP_PASSWORD=

# Optional token for future DNS-01 automation integrations.
# LE_DNS_API_TOKEN=
